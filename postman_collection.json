					"name": "Histórico de Pesagens (por período)",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/reports/weighing-history?startDate=2025-01-01T00:00:00Z&endDate=2027-12-31T23:59:59Z",
							"host": ["{{baseUrl}}"],
							"path": ["api", "reports", "weighing-history"],
							"query": [
								{ "key": "startDate", "value": "2025-01-01T00:00:00Z" },
								{ "key": "endDate", "value": "2027-12-31T23:59:59Z" }
							]
						}
					}
